APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=America/Mexico_City

# ------------------------------------------------------------------
# Impresoras POS (nueva configuracion central)
# ------------------------------------------------------------------
IMPRESORA_COCINA_DRIVER=usb
IMPRESORA_COCINA_IP=
IMPRESORA_COCINA_PUERTO=9100
IMPRESORA_COCINA_NOMBRE=
IMPRESORA_COCINA_SHARE=
IMPRESORA_COCINA_TIMEOUT=3
IMPRESORA_COCINA_CARACTERES=48
IMPRESORA_COCINA_CORTE=true
IMPRESORA_COCINA_ABRIR_CAJA=false
IMPRESORA_COCINA_FALLBACK_HTML=true
IMPRESORA_COCINA_HEADER="COMANDA COCINA"

IMPRESORA_BARRA_DRIVER=usb
IMPRESORA_BARRA_IP=
IMPRESORA_BARRA_PUERTO=9100
IMPRESORA_BARRA_NOMBRE=
IMPRESORA_BARRA_SHARE=
IMPRESORA_BARRA_TIMEOUT=3
IMPRESORA_BARRA_CARACTERES=48
IMPRESORA_BARRA_CORTE=true
IMPRESORA_BARRA_ABRIR_CAJA=false
IMPRESORA_BARRA_FALLBACK_HTML=true
IMPRESORA_BARRA_HEADER="COMANDA BARRA"

IMPRESORA_VENTAS_DRIVER=usb
IMPRESORA_VENTAS_IP=
IMPRESORA_VENTAS_PUERTO=9100
IMPRESORA_VENTAS_NOMBRE=
IMPRESORA_VENTAS_SHARE=
IMPRESORA_VENTAS_TIMEOUT=3
IMPRESORA_VENTAS_ANCHO_MM=80
IMPRESORA_VENTAS_CARACTERES=48
IMPRESORA_VENTAS_CORTE=true
IMPRESORA_VENTAS_ABRIR_CAJA=false
IMPRESORA_VENTAS_FALLBACK_HTML=true
IMPRESORA_VENTAS_TIENDA_NOMBRE="BRUMA CAFE"
IMPRESORA_VENTAS_TIENDA_DIRECCION=""
IMPRESORA_VENTAS_TIENDA_TELEFONO=""
IMPRESORA_VENTAS_CAJERO_DEFAULT="Sistema"

THERMAL_PRINTER_CONNECTION=usb
THERMAL_PRINTER_USB_NAME=
THERMAL_PRINTER_IP=
THERMAL_PRINTER_PORT=9100
THERMAL_PRINTER_TIMEOUT=3
THERMAL_PRINTER_WIDTH_MM=80
THERMAL_PRINTER_CHARACTERS_PER_LINE=48
THERMAL_PRINTER_CUT=true
THERMAL_PRINTER_OPEN_DRAWER=false
THERMAL_PRINTER_FALLBACK_HTML=true
THERMAL_STORE_NAME="BRUMA CAFE"
THERMAL_STORE_ADDRESS=""
THERMAL_STORE_PHONE=""
THERMAL_DEFAULT_CASHIER="Sistema"

COCINA_PRINTER_CONNECTION=usb
COCINA_PRINTER_USB_NAME=
COCINA_PRINTER_IP=
COCINA_PRINTER_PORT=9100
COCINA_PRINTER_TIMEOUT=3
COCINA_PRINTER_CHARACTERS_PER_LINE=48
COCINA_PRINTER_CUT=true
COCINA_PRINTER_HEADER="COMANDA COCINA"

BARRA_PRINTER_CONNECTION=usb
BARRA_PRINTER_USB_NAME=
BARRA_PRINTER_IP=
BARRA_PRINTER_PORT=9100
BARRA_PRINTER_TIMEOUT=3
BARRA_PRINTER_CHARACTERS_PER_LINE=48
BARRA_PRINTER_CUT=true
BARRA_PRINTER_HEADER="COMANDA BARRA"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_TIMEZONE=-06:00
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
